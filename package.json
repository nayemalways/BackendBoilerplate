  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --watch src --exec ts-node ./src/server.ts",
    "lint": "npx eslint ./src",
    "build": "tsc && npm run copy:docs && npm run copy:templates",
    "copy:docs": "copyfiles -u 2 src/app/docs/**/* dist/app/",
    "copy:templates": "copyfiles -u 4 src/app/utils/templates/**/* dist/app/utils/templates",
    "format": "npx prettier --write .",
    "start": "node dist/server.js"
  },
